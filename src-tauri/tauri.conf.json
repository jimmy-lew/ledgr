{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ledgr",
  "version": "0.1.0",
  "identifier": "app.ledgr.mobile",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": ".output/public",
    "devtools": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ledgr",
        "width": 400,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 320,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["android", "ios"],
    "android": {
      "minSdkVersion": 24,
      "targetSdkVersion": 34,
      "buildToolsVersion": "34.0.0"
    },
    "ios": {
      "minimumOSVersion": "13.0"
    }
  }
}
